<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculadora de Eixos"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tamanho do Eixo no Pino 0 (m):"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editTamanhoBase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: 1.0"
            android:inputType="numberDecimal"
            android:text="1.0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Circunferência desejada (m):"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editCircunferenciaDesejada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: 9.0"
            android:inputType="numberDecimal"
            android:text="9.0"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnDistribuir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calcular Distribuição dos Eixos"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sugestão de Eixos (Arredondado 5cm):"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Eixos sugeridos -->
        <TextView android:id="@+id/txtSugestaoEixos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eixos: 1.50m cada"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtCircunferenciaReal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Circunferência Real: 9.00 m"
            android:textSize="16sp"
            android:textColor="@android:color/black" />

    </LinearLayout>
</ScrollView>